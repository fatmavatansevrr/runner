{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PlanTemplateDefinition",
  "type": "object",
  "properties": {
    "metadata": {
      "type": "object",
      "properties": {
        "documentType": { "const": "PLAN_TEMPLATE" },
        "schemaVersion": { "type": "integer", "minimum": 1 },
        "key": { "type": "string", "minLength": 1 },
        "version": { "type": "integer", "minimum": 1 },
        "status": { "type": "string", "enum": ["DRAFT", "VALIDATED", "PUBLISHED", "RETIRED"] },
        "contentHash": { "type": "string" }
      },
      "required": ["documentType", "schemaVersion", "key", "version", "status"]
    },
    "distanceFamily": { "type": "string", "enum": ["FIVE_K", "TEN_K", "HALF_MARATHON", "MARATHON"] },
    "coreCycle": {
      "type": "object",
      "properties": {
        "minimumWeeks": { "type": "integer", "minimum": 1 },
        "defaultWeeks": { "type": "integer", "minimum": 1 },
        "maximumWeeks": { "type": "integer", "minimum": 1 }
      },
      "required": ["minimumWeeks", "defaultWeeks", "maximumWeeks"]
    },
    "supportedRunsPerWeek": { "type": "array", "items": { "type": "integer", "minimum": 1 }, "minItems": 1 },
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "properties": {
          "phaseKey": { "type": "string", "enum": ["FOUNDATION", "BUILD", "RACE_SPECIFIC", "TAPER"] },
          "minimumWeeks": { "type": "integer", "minimum": 0 },
          "preferredWeeks": { "type": "integer", "minimum": 0 },
          "maximumWeeks": { "type": "integer", "minimum": 0 },
          "intents": { "type": "array", "items": { "type": "string" } },
          "eligibleWorkoutFamilies": { "type": "array", "items": { "type": "string", "enum": ["EASY", "LONG_RUN", "QUALITY", "RACE"] } },
          "compressionPriority": { "type": "integer" },
          "extensionPriority": { "type": "integer" },
          "isCompressionProtected": { "type": "boolean" }
        },
        "required": ["phaseKey", "minimumWeeks", "preferredWeeks", "maximumWeeks", "intents", "eligibleWorkoutFamilies", "compressionPriority", "extensionPriority", "isCompressionProtected"]
      }
    },
    "workoutProgression": {
      "type": "object",
      "properties": {
        "documentType": { "const": "WORKOUT_PROGRESSION" },
        "key": { "type": "string" },
        "version": { "type": "integer" }
      },
      "required": ["documentType", "key", "version"]
    },
    "requiredRules": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "documentType": { "type": "string" },
          "key": { "type": "string" },
          "version": { "type": "integer" }
        },
        "required": ["documentType", "key", "version"]
      }
    },
    "requiredRuleKeys": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["metadata", "distanceFamily", "coreCycle", "supportedRunsPerWeek", "phases", "workoutProgression"],
  "oneOf": [
    { "required": ["requiredRules"], "not": { "required": ["requiredRuleKeys"] } },
    { "required": ["requiredRuleKeys"], "not": { "required": ["requiredRules"] } }
  ]
}
